{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/ensure-pnpm.mjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "backend:build": "pnpm --filter @workspace/api-server run build",
    "backend:compose:down": "docker compose -f artifacts/api-server/docker-compose.yml down -v",
    "backend:compose:up": "docker compose -f artifacts/api-server/docker-compose.yml up --build",
    "backend:dev": "pnpm --filter @workspace/api-server run dev",
    "backend:lint": "pnpm --filter @workspace/api-server run lint",
    "backend:test": "pnpm --filter @workspace/api-server run test",
    "railway:api:build": "pnpm --filter @workspace/api-server run prisma:generate && pnpm --filter @workspace/api-server run build",
    "railway:api:start": "node artifacts/api-server/scripts/start-railway.mjs",
    "railway:web:build": "pnpm --filter @workspace/ai-exposure-review run build",
    "railway:web:start": "node artifacts/ai-exposure-review/server.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
