NODE_ENV=development
SERVICE_NAME=ai-exposure-review-api
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
API_PREFIX=/api/v1
SWAGGER_ENABLED=true
SWAGGER_PATH=/docs
TRUST_PROXY=false
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_exposure_review?schema=public
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=1h
RATE_LIMIT_MAX=200
RATE_LIMIT_TIME_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_TIME_WINDOW_MS=60000
INTEGRATION_TOKEN_ENCRYPTION_SECRET=replace-this-with-a-long-random-integration-secret
GITHUB_BASE_URL=https://github.com
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OAUTH_SCOPES=repo read:user
GITHUB_OAUTH_STATE_TTL_MINUTES=10
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/integrations/github/callback
GITHUB_USE_MOCK=true
DEMO_USER_EMAIL=demo@ai-exposure-review.local
DEMO_USER_PASSWORD=DemoPassword123!
DEMO_WORKSPACE_NAME=Demo Workspace
DEMO_WORKSPACE_SLUG=demo-workspace
POSTGRES_DB=ai_exposure_review
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
